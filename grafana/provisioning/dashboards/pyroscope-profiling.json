{
  "title": "Continuous Profiling (Pyroscope)",
  "uid": "pyroscope-profiling",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["pyroscope", "profiling", "ebpf"],
  "panels": [
    {
      "id": 1,
      "title": "Profiles Received (samples/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(pyroscope_distributor_received_samples_sum{cluster=\"local\"}[1m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Head Block — Active Profiles",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum(pyroscope_head_profiles{cluster=\"local\"})",
          "legendFormat": "active profiles",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ingested Sample Values/s (by profile type)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (profile_name) (rate(pyroscope_head_ingested_sample_values_total{cluster=\"local\"}[1m]))",
          "legendFormat": "{{profile_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate to Pyroscope (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (handler, method) (rate(pyroscope_request_duration_seconds_count{cluster=\"local\"}[1m]))",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Request Latency p95 (by handler)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(pyroscope_request_duration_seconds_bucket{cluster=\"local\"}[1m])))",
          "legendFormat": "p95 {{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Head Block Size (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (component) (pyroscope_head_size_bytes{cluster=\"local\"})",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pyroscope Process CPU (cores)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{cluster=\"local\", job=\"pyroscope\"}[1m])",
          "legendFormat": "cpu cores used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Pyroscope Heap Memory (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "go_memstats_heap_inuse_bytes{cluster=\"local\", job=\"pyroscope\"}",
          "legendFormat": "heap in-use",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Total Profiles in Head",
      "type": "stat",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(pyroscope_head_profiles{cluster=\"local\"})",
          "legendFormat": "profiles",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Distributor Ingester Clients",
      "type": "stat",
      "gridPos": { "x": 6, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "pyroscope_distributor_ingester_clients{cluster=\"local\"}",
          "legendFormat": "ingester clients",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Discarded Samples/s",
      "type": "stat",
      "gridPos": { "x": 12, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(pyroscope_discarded_samples_total{cluster=\"local\"}[1m]))",
          "legendFormat": "discarded/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Replication Factor",
      "type": "stat",
      "gridPos": { "x": 18, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "pyroscope_distributor_replication_factor{cluster=\"local\"}",
          "legendFormat": "replication factor",
          "refId": "A"
        }
      ]
    }
  ]
}
